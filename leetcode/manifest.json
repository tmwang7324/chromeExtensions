{
    "name": "LeetCode Solutions Tracker",
    "description": "Detect accepted LeetCode submissions, capture reflection notes, and append the record to Google Sheets.",
    "version": "1.0.0",
    "manifest_version": 3,
    "action": {
        "default_title": "LeetCode Tracker",
        "default_popup": "popup.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "permissions": [
        "storage",
        "scripting",
        "tabs"
    ],
    "host_permissions": [
        "https://leetcode.com/*",
        "https://script.google.com/*",
        "https://script.googleusercontent.com/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://leetcode.com/problems/*"
            ],
            "js": [
                "inject.js"
            ],
            "run_at": "document_start",
            "world": "MAIN"
        },
        {
            "matches": [
                "https://leetcode.com/problems/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}